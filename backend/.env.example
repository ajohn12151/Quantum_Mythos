# Copy to .env and fill in. Build against local Postgres first, swap to Aurora later.
# Local:  postgresql://postgres:postgres@localhost:5432/quantum_mythos
# Aurora: postgresql://<user>:<pass>@<cluster-endpoint>:5432/<db>
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/quantum_mythos

# For the white-box reasoning layer (Claude) and remediation PRs.
ANTHROPIC_API_KEY=
GITHUB_TOKEN=

# CORS origin for Alan's Vercel frontend (comma-separated). "*" for local dev.
CORS_ORIGINS=*
