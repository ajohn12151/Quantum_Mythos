# Supabase — copy to .env and fill from your Supabase project dashboard
# (Project Settings → API). Vite exposes only VITE_-prefixed vars to the client.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_OR_ANON_KEY
VITE_SUPABASE_PROJECT_ID=YOUR_PROJECT_ID

# Server-side equivalents (used during SSR)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_OR_ANON_KEY
SUPABASE_PROJECT_ID=YOUR_PROJECT_ID

# Note: with no keys set, the app still runs — the guard falls back to the
# opt-in "Explore the live demo" session so every screen stays reachable.
